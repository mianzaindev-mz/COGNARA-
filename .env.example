# Copy to .env.local and fill values. Never commit .env.local.

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI MODELS ─────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── CODE COMPILER (Judge0 CE) ─────────────────────────────
JUDGE0_API_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ── PAYMENTS (Stripe) ─────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STUDENT_PRO_PRICE_ID=
STRIPE_COACH_STARTER_PRICE_ID=
STRIPE_COACH_PRO_PRICE_ID=
STRIPE_CREDITS_100_PRICE_ID=
STRIPE_CREDITS_500_PRICE_ID=
STRIPE_CREDITS_2000_PRICE_ID=
STRIPE_CREDITS_10000_PRICE_ID=

# ── VIDEO ─────────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
NEXT_PUBLIC_MUX_ENV_KEY=

# ── LIVE CLASSES ──────────────────────────────────────────
DAILY_API_KEY=

# ── EMAIL ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=COGNARA

# ── RATE LIMITING (Upstash) ───────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── ERROR MONITORING (Sentry) ─────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── APP CONFIG ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=COGNARA
NEXT_PUBLIC_APP_VERSION=1.0.0
